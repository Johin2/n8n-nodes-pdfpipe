{
  "name": "n8n-nodes-pdfpipe",
  "version": "1.1.5",
  "description": "n8n community node for PDFPipe: render HTML or URLs to pixel-perfect PDFs, batch render, and manage stored documents.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "pdf",
    "html-to-pdf",
    "url-to-pdf",
    "pdfpipe"
  ],
  "license": "MIT",
  "homepage": "https://pdfpipe.xyz",
  "author": {
    "name": "Johin Johny",
    "email": "johinjohny144@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Johin2/n8n-nodes-pdfpipe.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && node copy-icons.mjs"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PDFPipeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PDFPipe/PDFPipe.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "n8n-workflow": "^1.70.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.10"
  }
}
